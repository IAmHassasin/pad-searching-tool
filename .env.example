# Copy → `.env` rồi chạy README Quick start (Docker):
#   cp .env.example .env
#   docker compose -f docker-compose.yml -f docker-compose.cloud.yml up -d --build
# Entrypoint tải COMMUNITY_DB_URL vào volume /data/pad.db — không cần file seed trên host.
# `npm run pad` (local) cũng load `.env`.

# --- Community DB (SQLite — không dùng dadguide.mysql) ---
COMMUNITY_DB_URL=https://d30r6ivozz8w2a.cloudfront.net/db/dadguide.sqlite
# EXTERNAL_DB_URL=
# Tải seed local: npm run pad -- seed-db  (ưu tiên DB_DOWNLOAD_URL, else COMMUNITY_DB_URL)
DB_DOWNLOAD_URL=

# Working DB trên máy host (npm run pad -- merge / serve). Docker ghi đè thành /data/pad.db.
SQLITE_PATH=./seed/dadguide.sqlite
# Output của seed-db (mặc định ./seed/dadguide.sqlite)
# SEED_DB_PATH=./seed/dadguide.sqlite

# --- Docker bind-mount seed (tùy chọn) ---
# Mặc định URL-only: giữ comment + dùng docker-compose.cloud.yml (README Quick start).
# Chỉ bật khi đã có FILE ./seed/dadguide.sqlite và chạy `docker compose` (không cloud override):
# SQLITE_SNAPSHOT_PATH=/seed/dadguide.sqlite

# --- npm run pad -- snapshot (immutable file trên máy) ---
# SNAPSHOT_OUTPUT_PATH=./local/community-pad.sqlite

# --- Merge / replace ---
IMPORT_MODE=merge
IMPORT_KEEP_LOCAL_TABLES=pad_categorized,skill_tag,skill_tag_manual
# IMPORT_SKIP_TABLES=
IMPORT_BACKUP=false

# --- Categorize ---
# monsters + active_skills + leader_skills; chỉ các cột cần (đồng bộ với SOURCE_COLUMN_WHITELIST).
SOURCE_TABLE=monsters_join_skills
SOURCE_ID_COLUMN=monster_id
SOURCE_QUERY=SELECT m.monster_id, m.monster_no_na, m.name_en, m.name_ja AS name_jp, m.base_id, m.group_id, m.collab_id, m.awakenings, m.hp_max, m.atk_max, m.rcv_max, m.rarity, m.attribute_1_id, m.attribute_2_id, m.attribute_3_id, m.type_1_id, m.type_2_id, m.type_3_id, m.sync_awsid, m.super_awakenings, a.name_en AS active_skill_name_en, a.desc_en AS active_skill_desc_en, a.cooldown_turns_min AS active_skill_cooldown_min, a.cooldown_turns_max AS active_skill_cooldown_max, a.tags AS active_skill_tags, l.name_en AS leader_skill_name_en, l.desc_en AS leader_skill_desc_en, l.tags AS leader_skill_tags FROM monsters m LEFT JOIN active_skills a ON m.active_skill_id = a.active_skill_id LEFT JOIN leader_skills l ON m.leader_skill_id = l.leader_skill_id
# Sau khi load row, chỉ giữ các cột sau (+ luôn giữ __source_pk / __rowid nội bộ).
SOURCE_COLUMN_WHITELIST=monster_id,monster_no_na,name_en,name_jp,base_id,group_id,collab_id,awakenings,hp_max,atk_max,rcv_max,rarity,attribute_1_id,attribute_2_id,attribute_3_id,type_1_id,type_2_id,type_3_id,active_skill_name_en,active_skill_desc_en,active_skill_cooldown_min,active_skill_cooldown_max,active_skill_tags,sync_awsid,super_awakenings,leader_skill_name_en,leader_skill_desc_en,leader_skill_tags
# CATEGORY_FROM_COLUMN=
# SUBCATEGORY_FROM_COLUMN=
# Quy tắc theo JSON: mỗi mục có thể thêm patterns / regex / matchAll (xem docs/filter-type-categories.json).
FILTER_TYPE_CATEGORIES_PATH=docs/filter-type-categories.json
# Cột mặc định để so khớp (alias trong SOURCE_QUERY): dadguide dùng active_skill_desc_en.
FILTER_DESC_COLUMN=active_skill_desc_en
# Cột tags: active_skills.tags / leader_skills.tags dạng "(9),(80),(240)".
FILTER_TAGS_COLUMN=active_skill_tags
# Quy tắc label "LS - …" dùng cột này (leader_skill_tags lookup).
FILTER_LEADER_TAGS_COLUMN=leader_skill_tags
# Sau transform: mỗi category → 1 file JSON + index.json (legacy; UI dùng pattern search).
CATEGORY_JSON_EXPORT_DIR=exports/category-bundles

# --- Pattern-based skill search (GET /patterns/groups, GET /monsters/search) ---
PATTERNS_GROUP_PATH=exports/patterns/patterns_group.json
PATTERNS_CATALOG_PATH=exports/patterns/pad_generated_patterns.json
PATTERN_ACTIVE_DESC_COLUMN=active_skill_desc_en
PATTERN_LEADER_DESC_COLUMN=leader_skill_desc_en
INSERT_BATCH=500

# --- Superadmin (cloud secrets — không commit giá trị thật) ---
# Bật UI Admin + POST /admin/refresh-db trên web.
ADMIN_USERNAME=superadmin
ADMIN_PASSWORD=replace-with-long-random-secret
ADMIN_JWT_SECRET=replace-with-32plus-char-random-secret
ADMIN_TOKEN_TTL_HOURS=12

# --- HTTP API (CLI: pad serve ép START_HTTP=true) ---
RUN_TRANSFORM=true
START_HTTP=false
HTTP_PORT=3000
HTTP_HOST=0.0.0.0
HTTP_PUBLISH_PORT=3000
TYPEORM_SYNC=true

# --- API: GET /awoken-skills (phân trang limit/offset) ---
# AWOKEN_SKILLS_TABLE=awoken_skills

# --- GameWith vanish supplement (assist active-skill awoken grants) ---
# Manual: npm run pad -- import-vanish-db
# Maps GameWith JP names → awoken_skill_id via dadguide name_ja + seed/vanish-awoken-name-map.json.
# GameWith vanish supplement DB — baked into Docker image (npm run pad -- import-vanish-db).
# Docker Compose sets VANISH_AWOKEN_SQLITE_PATH=/seed/gamewith-vanish.sqlite (see docker-compose.yml).
# VANISH_AWOKEN_SQLITE_PATH=./seed/gamewith-vanish.sqlite
# VANISH_AWOKEN_NAME_MAP_PATH=./seed/vanish-awoken-name-map.json
