# Đặt các giá trị thật tại `.env` (copy từ file này). `npm run pad` luôn load `.env`.

# --- Tải community DB (điều khi chạy pad merge / snapshot / Docker seed) ---
COMMUNITY_DB_URL=https://example.com/dadguide.sqlite
# EXTERNAL_DB_URL=
# Bật cho Docker: entrypoint tải seed rồi copy vào SQLITE_PATH trong container (/data/pad.db).
DB_DOWNLOAD_URL=

# File làm việc (có thể ghi pad_categorized). Dùng dadguide đầy đủ, không dùng pad.db rỗng.
SQLITE_PATH=./seed/dadguide.sqlite

# --- Seed Docker (immutable): path TRONG container — khớp volume compose (vd ./seed/dadguide.sqlite:/seed/dadguide.sqlite) ---
# Để chỉ tải URL, comment hết SQLITE_SNAPSHOT_PATH + COMMUNITY_DB_URL đủ cho entrypoint.
SQLITE_SNAPSHOT_PATH=/seed/dadguide.sqlite

# --- npm run pad -- snapshot (immutable file trên máy) ---
# SNAPSHOT_OUTPUT_PATH=./local/community-pad.sqlite

# --- Merge / replace ---
IMPORT_MODE=merge
IMPORT_KEEP_LOCAL_TABLES=pad_categorized,skill_tag,skill_tag_manual
# IMPORT_SKIP_TABLES=
IMPORT_BACKUP=false

# --- Categorize ---
# monsters + active_skills + leader_skills; chỉ các cột cần (đồng bộ với SOURCE_COLUMN_WHITELIST).
SOURCE_TABLE=monsters_join_skills
SOURCE_ID_COLUMN=monster_id
SOURCE_QUERY=SELECT m.monster_id, m.monster_no_na, m.name_en, m.name_ja AS name_jp, m.awakenings, m.hp_max, m.atk_max, m.rcv_max, m.rarity, m.attribute_1_id, m.attribute_2_id, m.attribute_3_id, m.sync_awsid, m.super_awakenings, a.desc_en AS active_skill_desc_en, l.desc_en AS leader_skill_desc_en FROM monsters m LEFT JOIN active_skills a ON m.active_skill_id = a.active_skill_id LEFT JOIN leader_skills l ON m.leader_skill_id = l.leader_skill_id
# Sau khi load row, chỉ giữ các cột sau (+ luôn giữ __source_pk / __rowid nội bộ).
SOURCE_COLUMN_WHITELIST=monster_id,monster_no_na,name_en,name_jp,awakenings,hp_max,atk_max,rcv_max,rarity,attribute_1_id,attribute_2_id,attribute_3_id,active_skill_desc_en,sync_awsid,super_awakenings,leader_skill_desc_en
# CATEGORY_FROM_COLUMN=
# SUBCATEGORY_FROM_COLUMN=
INSERT_BATCH=500

# --- HTTP API (CLI: pad serve ép START_HTTP=true) ---
RUN_TRANSFORM=true
START_HTTP=false
HTTP_PORT=3000
HTTP_HOST=0.0.0.0
HTTP_PUBLISH_PORT=3000
TYPEORM_SYNC=true

# --- API: GET /awoken-skills (phân trang limit/offset) ---
# AWOKEN_SKILLS_TABLE=awoken_skills
